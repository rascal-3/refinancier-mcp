{
  "name": "refinancier-mcp",
  "version": "0.0.3",
  "description": "MCP client for refinancier — Trust Infrastructure for Uncertain Assets. Enterprise valuation, anomaly detection, and value-up recommendations for AI agents.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "refinancier-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "claude_desktop_config.example.json"
  ],
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx --watch src/index.ts",
    "build": "tsc && chmod +x dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "refinancier",
    "enterprise-valuation",
    "causal-ai",
    "xai",
    "decision-intelligence",
    "ai-agent",
    "anomaly-detection",
    "value-up"
  ],
  "author": "refinancier, inc.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rascal-3/refinancier-mcp.git"
  },
  "homepage": "https://refinancier-banks.com",
  "bugs": {
    "url": "https://github.com/rascal-3/refinancier-mcp/issues"
  }
}
